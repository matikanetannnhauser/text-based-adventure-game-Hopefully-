def get_enemies_for_room(room_name):
    encounter = rooms[room_name].get("encounters", rooms[room_name].get("encounter"))
    if encounter is None:
        return []
    if isinstance(encounter, str):
        enemy = get_enemy_by_name(encounter)
        return [enemy] if enemy else []
    if isinstance(encounter, list):
        return [enemy for enemy in (get_enemy_by_name(name) for name in encounter) if enemy]
    return []


def reward_souls_for_enemy(opponent):
    reward = soul_rewards.get(opponent.name, 0)
    if reward > 0:
        add_souls(reward)


def loot_for_enemy(opponent):
    enemy_loot = {
        "Lothric Knight Sword": ["Lothric Knight Sword"],
        "Lothric Knight Spear": ["Lothric Knight Spear"],
        "Puss of Man": ["Estus Shard"],
    }
    return enemy_loot.get(opponent.name, [])


def choose_combat_target(enemies):
    alive_enemies = [enemy for enemy in enemies if enemy.is_alive()]
    if len(alive_enemies) == 1:
        return alive_enemies[0]

    print("\nChoose your target:")
    for index, enemy in enumerate(alive_enemies, start=1):
        print(f"{index}) {enemy.name} ({enemy.hp}/{enemy.max_hp} HP)")

    while True:
        choice = input("Target: ").strip()
        if choice.isdigit():
            choice_num = int(choice)
            if 1 <= choice_num <= len(alive_enemies):
                return alive_enemies[choice_num - 1]
        print("Invalid target.")


def start_combat(opponents):
    alive_names = ", ".join(enemy.name for enemy in opponents)
    if len(opponents) == 1:
        print(f"\nA {alive_names} approaches!\n")
    else:
        print(f"\nEnemies approach: {alive_names}\n")

    defending = False

    while player.is_alive() and any(enemy.is_alive() for enemy in opponents):
        alive_enemies = [enemy for enemy in opponents if enemy.is_alive()]

        print(
            f"{player.name} (Lv {player.level}): {player.hp}/{player.max_hp} HP | "
            f"Stamina: {player.stamina}/{player.max_stamina} | "
            f"Estus: {player.estus_flask}/{player.max_estus_flask} | "
            f"Souls: {player.souls}"
        )
        print(f"Stamina Bar: {format_bar(player.stamina, player.max_stamina)}")
        for enemy in alive_enemies:
            print(f"{enemy.name}: {enemy.hp}/{enemy.max_hp} HP")
        print("1) Attack  2) Heavy Attack  3) Block  4) Roll  5) Estus  0) Skip")
        choice = input("Choose action: ").strip().lower()

        if choice in ("1", "attack"):
            if not spend_stamina_for_action("attack"):
                continue
            target = choose_combat_target(alive_enemies)
            damage = player.total_attack_power()
            target.take_damage(damage)
            print(f"You deal {damage} damage to {target.name}.")
            if not target.is_alive():
                print(f"{target.name} has been defeated!\n")
                reward_souls_for_enemy(target)
        elif choice in ("2", "heavy attack", "heavy"):
            if not spend_stamina_for_action("heavy_attack"):
                continue
            target = choose_combat_target(alive_enemies)
            damage = player.attack_power + (15 if isinstance(target, Boss) else 10)
            target.take_damage(damage)
            print(f"You unleash a heavy attack on {target.name} for {damage} damage.")
            if not target.is_alive():
                print(f"{target.name} has been defeated!\n")
                reward_souls_for_enemy(target)
        elif choice in ("3", "block"):
            if not spend_stamina_for_action("block"):
                continue
            defending = True
            print("You raise your shield.")
            player.recover_stamina(20)
            print(f"You steady your stance and recover some stamina. Stamina: {player.stamina}/{player.max_stamina}")
        elif choice in ("4", "roll"):
            if not spend_stamina_for_action("roll"):
                continue
            defending = True
            print("You roll away from danger.")
        elif choice in ("5", "estus", "use estus"):
            estus_flask()
        elif choice in ("0", "skip"):
            print("You hesitate.")
        else:
            print("Invalid choice.")
            continue

        if not any(enemy.is_alive() for enemy in opponents):
            return "win"

        for enemy in [enemy for enemy in opponents if enemy.is_alive()]:
            enemy_damage = enemy.choose_attack_damage() if isinstance(enemy, Boss) else enemy.attack_power
            if defending:
                enemy_damage = max(0, enemy_damage - 10)
            player.take_damage(enemy_damage)
            print(f"{enemy.name} hits you for {enemy_damage} damage.")
            if not player.is_alive():
                break

        defending = False
        player.recover_stamina()

    if not player.is_alive():
        drop_souls_on_death()
        return death_screen()

    return "win"


def rest_at_bonfire():
    global defeated_enemies, last_bonfire

    if not rooms[current_location].get("bonfire"):
        print("You can only rest at a bonfire")
        return

    discover_current_bonfire()
    restore_player_resources()
    last_bonfire = current_location
    defeated_enemies = set()
    print("\nRest at Bonfire")
    print("Health and estus restored.")
    print("Stamina restored.")
    print("The world stirs again. Enemies have returned.")


def travel_between_bonfires():
    global current_location, last_bonfire

    if not rooms[current_location].get("bonfire"):
        print("You can only fast travel from a bonfire.")
        return

    discover_current_bonfire()
    available_bonfires = sorted(bonfire for bonfire in discovered_bonfires if bonfire != current_location)
    if not available_bonfires:
        print("No other bonfires have been discovered yet.")
        return

    print("\n== Fast Travel ==")
    for index, bonfire in enumerate(available_bonfires, start=1):
        print(f"{index}) {bonfire}")
    print("0) Cancel")

    choice = input("Choose bonfire: ").strip().lower()
    if choice in ("0", "cancel"):
        return

    travel_map = {str(index): bonfire for index, bonfire in enumerate(available_bonfires, start=1)}
    destination = travel_map.get(choice)
    if destination is None:
        print("Invalid choice.")
        return

    current_location = destination
    last_bonfire = destination
    restore_player_resources()
    discover_current_bonfire()
    print(f"\nYou travel to {destination}.")
    print("Health, estus, and stamina restored.")


def respawn_at_last_bonfire():
    global current_location, defeated_enemies

    restore_player_resources()
    current_location = last_bonfire
    discover_current_bonfire
    defeated_enemies = set()
    print(f"\nYou awaken at the bonfire: {last_bonfire}")
    print("Health, estus, and stamina restored.")


def move_player(direction):
    global current_location
    exits = rooms[current_location]["exit"]
    if direction not in exits:
        print("You cannot go that way.")
        return
    current_location = exits[direction]


def recover_stamina_after_turn():
    player.recover_stamina(15)


def list_items_in_location():
    location_items = rooms[current_location].get("items", [])
    if location_items:
        print("You see the following items:")
        for item in location_items:
            print(f"- {item}")


def get_exploration_prompt():
    options = []
    options.extend(rooms[current_location]["exit"].keys())
    if rooms[current_location].get("items"):
        options.append("pickup")
    options.extend(["inventory", "use"])
    if rooms[current_location].get("bonfire"):
        options.append("rest")
        if len(discovered_bonfires) > 1:
            options.append("travel")
        if current_location == "Firelink Shrine":
            options.extend(["level", "shop", "talk"])
    options.append("quit")
    return f"Choose action ({'/'.join(options)}): "


def pickup_item():
    location_items = rooms[current_location].get("items", [])
    if not location_items:
        print("There is nothing to pick up here.")
        return
    print("Items available to pick up:")
    for index, item in enumerate(location_items, start=1):
        print(f"{index}) {item}")
    print("0) Cancel")
    choice = input("Choose item to pick up: ").strip().lower()
    if choice in ("0", "cancel"):
        return
    if choice.isdigit():
        index = int(choice) - 1
        if 0 <= index < len(location_items):
            item_name = location_items.pop(index)
            player.add_to_inventory(item_name)
            print(f"You picked up {item_name}.")
            return
    print("Invalid choice.")


def use_item():
    if not player.inventory:
        print("Your inventory is empty.")
        return
    print("Inventory:")
    for index, item in enumerate(player.inventory, start=1):
        print(f"{index}) {item}")
    print("0) Cancel")
    choice = input("Choose item to use: ").strip().lower()
    if choice in ("0", "cancel"):
        return
    if choice.isdigit():
        index = int(choice) - 1
        if 0 <= index < len(player.inventory):
            item_name = player.inventory[index]
            handle_item_use(item_name)
            return
    print("Invalid choice.")


def handle_item_use(item_name):
    item = player.remove_from_inventory(item_name)
    if item is None:
        print("Item not found in inventory.")
        return
    item_lower = item.lower()
    if item_lower == "estus shard":
        player.max_estus_flask += 1
        player.estus_flask += 1
        print("You attune the Estus Shard. Estus capacity increased by 1.")
    elif item_lower == "health ring":
        player.max_hp += 10
        player.hp = min(player.hp + 10, player.max_hp)
        print("Your vitality grows stronger thanks to the ring.")
    elif item_lower in ("lothric knight sword", "lothric knight spear"):
        weapon_stats = {
            "Lothric Knight Sword": 15,
            "Lothric Knight Spear": 18,
        }
        if player.equipped_weapon.lower() == item_lower:
            print(f"{item} is already equipped.")
            player.add_to_inventory(item)
            return
        player.equip_weapon(item, weapon_stats)
        print(f"You equip the {item}. Attack power increased.")
    else:
        print(f"You use the {item}, but nothing happens.")


def display_inventory():
    print("\n== Inventory ==")
    print(f"Equipped Weapon: {player.equipped_weapon} (+{player.weapon_attack} attack)")
    if player.inventory:
        for item in player.inventory:
            print(f"- {item}")
    else:
        print("(empty)")


def run_game():
    reset_game_state()
    respawn_at_last_bonfire

    while player.is_alive():
        recover_dropped_souls()
        print(f"DEBUG current_location={current_location!r} type={type(current_location)} rooms_type={type(rooms)}")
        discover_current_bonfire()
        display_location()

        if current_location not in defeated_enemies and current_location not in defeated_boss_rooms:
            enemies = get_enemies_for_room(current_location)
            if enemies:
                combat_result = start_combat(enemies)
                if combat_result == "respawn":
                    respawn_at_last_bonfire()
                    continue
                if combat_result == "restart":
                    return "restart"
                if combat_result == "quit":
                    return "quit"
                defeated_enemies.add(current_location)
                if any(isinstance(enemy, Boss) for enemy in enemies):
                    defeated_boss_rooms.add(current_location)
                    print("\nHEIR OF FIRE DESTROYED")
                loot_items = []
                for enemy in enemies:
                    if not enemy.is_alive():
                        loot_items.extend(loot_for_enemy(enemy))
                if loot_items:
                    rooms[current_location].setdefault("items", []).extend(loot_items)
                    print("You found loot from defeated enemies:")
                    for loot in loot_items:
                        print(f"- {loot}")

        choice = input(get_exploration_prompt()).strip().lower()
        if choice == "quit":
            print("Farewell, Ashen One")
            return "quit"
        if choice == "rest":
            rest_at_bonfire()
            recover_stamina_after_turn()
            continue
        if choice == "travel" and rooms[current_location].get("bonfire"):
            travel_between_bonfires()
            recover_stamina_after_turn()
            continue
        if choice == "pickup":
            pickup_item()
            continue
        if choice == "inventory":
            display_inventory()
            continue
        if choice == "use":
            use_item()
            continue
        if choice == "level" and current_location == "Firelink Shrine":
            level_up_at_firelink()
            continue
        if choice == "shop" and current_location == "Firelink Shrine":
            soul_shop_at_firelink()
            continue
        if choice == "talk" and current_location == "Firelink Shrine":
            print("Who do you want to speak with? (firekeeper/handmaid)")
            npc_choice = input("Choose NPC: ").strip().lower()
            if npc_choice in ("firekeeper", "1"):
                level_up_at_firelink()
            elif npc_choice in ("handmaid", "merchant", "2"):
                soul_shop_at_firelink()
            else:
                print("You remain silent.")
            continue
        if choice in ("north", "south", "east", "west"):
            move_player(choice)
            recover_stamina_after_turn()
            continue

        print("Invalid choice.")

    return "restart"


while True:
    outcome = run_game()
    if outcome != "restart":
        break