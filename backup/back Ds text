def level_up_cost():
    return 100 + ((player.level - 1) * 50)


def level_up_at_firelink():
    if current_location != "Firelink Shrine":
        print("You can only level up at Firelink Shrine.")
        return

    cost = level_up_cost()
    print(f"\n== {rooms[current_location]['level_npc']} ==")
    print("Touch the darkness within me. Take nourishment from these sovereignless souls.")
    print("\n== Level Up ==")
    print(f"Level: {player.level}")
    print(f"Souls: {player.souls} / {cost}")
    print("1) Vitality (+20 max HP)")
    print("2) Endurance (+10 max stamina)")
    print("3) Strength (+5 attack)")
    print("4) Recovery (+5 stamina recovery)")
    print("0) Cancel")

    choice = input("Choose level up: ").strip().lower()
    if choice in ("0", "cancel"):
        return
    if player.souls < cost:
        print("Not enough souls to level up.")
        return

    upgrades = {
        "1": "vitality",
        "vitality": "vitality",
        "2": "endurance",
        "endurance": "endurance",
        "3": "strength",
        "strength": "strength",
        "4": "recovery",
        "recovery": "recovery",
    }
    upgrade = upgrades.get(choice)
    if upgrade is None:
        print("Invalid choice.")
        return

    player.souls -= cost
    player.level += 1

    if upgrade == "vitality":
        player.max_hp += 20
        player.hp = player.max_hp
        print("Vitality increased.")
    elif upgrade == "endurance":
        player.max_stamina += 10
        player.stamina = player.max_stamina
        print("Endurance increased.")
    elif upgrade == "strength":
        player.attack_power += 5
        print("Strength increased.")
    elif upgrade == "recovery":
        player.stamina_recovery += 5
        print("Stamina recovery increased.")

    print(f"You are now level {player.level}.")
    

