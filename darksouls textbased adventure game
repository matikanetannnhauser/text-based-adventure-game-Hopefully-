def heal_player(heal_amount):
    player.hp = min(player.hp + heal_amount, player.max_hp)
    print(f"{player.name} drank from their estus flask for {heal_amount} HP.")
    print(f"Current Health: {player.hp}/{player.max_hp}")


def format_bar(current, maximum, width=20):
    filled = int((current / maximum) * width) if maximum else 0
    filled = max(0, min(width, filled))
    empty = width - filled
    return f"[{('#' * filled)}{('-' * empty)}] {current}/{maximum}"


def restore_player_resources():
    player.hp = player.max_hp
    player.estus_flask = player.max_estus_flask
